{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["docs/.vitepress/theme/*"]
    },
    "moduleResolution": "bundler",
    "target": "ESNext",
    "module": "ESNext",
    "strict": false,
    "jsx": "preserve",
    "lib": ["ESNext", "DOM"],
    "skipLibCheck": true
  },
  "include": ["docs/.vitepress/theme/**/*"]
}
